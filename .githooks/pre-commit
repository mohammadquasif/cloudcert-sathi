#!/bin/sh

author_name=$(git config user.name)
author_email=$(git config user.email)

author_name_lower=$(echo "$author_name" | tr '[:upper:]' '[:lower:]')
author_email_lower=$(echo "$author_email" | tr '[:upper:]' '[:lower:]')

# Check for unauthorized AI agent footprints in name/email
forbidden="shizisoftwares claude codex agent bot ai-agent"
for pattern in $forbidden; do
  if echo "$author_name_lower" | grep -q "$pattern" || echo "$author_email_lower" | grep -q "$pattern"; then
    echo "=========================================================="
    echo "Error: Commits from '$pattern' or AI agents are strictly forbidden."
    echo "Current Git user.name: $author_name"
    echo "Current Git user.email: $author_email"
    echo "=========================================================="
    exit 1
  fi
done

# Check that the author is strictly mohammadquasif
if ! echo "$author_name_lower" | grep -q "mohammadquasif"; then
    echo "=========================================================="
    echo "Error: Only 'mohammadquasif' is allowed to commit to this repository."
    echo "Current Git user.name: $author_name"
    echo "Please configure your git user.name: git config user.name 'mohammadquasif'"
    echo "=========================================================="
    exit 1
fi

exit 0
